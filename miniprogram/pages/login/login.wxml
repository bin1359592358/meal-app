<view class="page">
  <view class="brand-hero">
    <view class="hero-glow"></view>
    <image class="brand-avatar" src="/images/brand/avatar.jpg" mode="aspectFill" />
    <view class="brand-copy">
      <text class="brand-eyebrow">WELCOME TO MY KITCHEN</text>
      <text class="brand-title">超大一碗饭</text>
      <text class="subtitle">今天也要好好吃饭</text>
    </view>
  </view>

  <view class="card fallback-card" wx:if="{{loginFailed}}">
    <text class="fallback-notice">{{loginError}}</text>
    <view class="fallback-form">
      <input class="input" placeholder="用户名（字母+数字）" value="{{fbUsername}}" bindinput="onFbUsernameInput" />
      <input wx:if="{{fbMode === 'register'}}" class="input" placeholder="昵称" value="{{fbNickname}}" bindinput="onFbNicknameInput" />
      <input class="input" placeholder="密码（4-6位数字）" type="number" value="{{fbPin}}" bindinput="onFbPinInput" maxlength="6" />
      <button class="btn-primary" bindtap="onFallbackLogin" disabled="{{loading}}">{{fbMode === 'login' ? '登录' : '注册'}}</button>
      <view class="fallback-actions">
        <text class="switch-link" bindtap="onFbModeSwitch">{{fbMode === 'login' ? '没有账号？去注册' : '已有账号？去登录'}}</text>
        <text class="switch-link" bindtap="onRetryWxLogin">重试微信登录</text>
      </view>
    </view>
  </view>

  <view class="workspace-card">
    <view class="tabs" wx:if="{{!loginFailed || fbUsername}}">
      <view class="tab {{activeTab === 'create' ? 'tab--active' : ''}}" bindtap="onTabTap" data-tab="create">创建餐桌</view>
      <view class="tab {{activeTab === 'join' ? 'tab--active' : ''}}" bindtap="onTabTap" data-tab="join">加入餐桌</view>
    </view>
    <view wx:if="{{loginFailed && !fbUsername}}" class="login-hint">请先完成账号登录</view>
    <view class="form-panel" wx:if="{{activeTab === 'create'}}">
      <text class="card-title">开一桌新的好味道</text>
      <text class="card-desc">创建后分享邀请码，就能一起点菜。</text>
      <input class="input" placeholder="给餐桌起个名字" value="{{roomName}}" bindinput="onRoomNameInput" maxlength="20" />
      <button class="btn-primary" bindtap="onCreateRoom" disabled="{{!roomName || loading}}">{{loading ? '创建中...' : '创建餐桌'}}</button>
    </view>
    <view class="form-panel" wx:if="{{activeTab === 'join'}}">
      <text class="card-title">主厨已经为你留座</text>
      <text class="card-desc">输入邀请码，马上看看今天的菜单。</text>
      <input class="input code-input" placeholder="输入邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" maxlength="10" />
      <button class="btn-primary" bindtap="onJoinRoom" disabled="{{!inviteCode || loading}}">{{loading ? '加入中...' : '加入餐桌'}}</button>
    </view>
  </view>
  <text class="footer-note">饭宝为每一餐认真准备</text>
</view>
