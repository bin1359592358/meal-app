.page{min-height:100vh;background:linear-gradient(180deg,#EAF1FF 0,#FFFDF8 46%);padding:44rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));box-sizing:border-box}
.brand-hero{height:410rpx;position:relative;display:flex;align-items:center;overflow:hidden;margin:0 -36rpx 22rpx;padding:0 44rpx}.hero-glow{position:absolute;width:400rpx;height:400rpx;border-radius:50%;background:rgba(255,223,160,.7);right:-70rpx;top:-90rpx;filter:blur(2rpx)}
.brand-avatar{position:absolute;right:18rpx;bottom:-20rpx;width:330rpx;height:330rpx;border-radius:50%;border:10rpx solid rgba(255,255,255,.72);box-shadow:0 20rpx 50rpx rgba(53,88,143,.18)}
.brand-copy{position:relative;z-index:2;width:390rpx;display:flex;flex-direction:column}.brand-eyebrow{font-size:18rpx;letter-spacing:2rpx;color:#5579BC;font-weight:700}.brand-title{font-size:54rpx;font-weight:800;color:#30394A;letter-spacing:2rpx;margin:16rpx 0 10rpx;text-shadow:0 2rpx 0 #fff}.subtitle{font-size:27rpx;color:#62708A}
.workspace-card,.fallback-card{background:rgba(255,255,255,.96);border:1rpx solid rgba(85,121,188,.14);border-radius:32rpx;padding:18rpx;box-shadow:0 18rpx 45rpx rgba(53,88,143,.1);margin-bottom:24rpx}.fallback-card{padding:30rpx}.fallback-notice{display:block;color:#A66F14;font-size:25rpx;line-height:1.5;margin-bottom:22rpx}
.tabs{display:flex;background:#F4F7FC;border-radius:22rpx;padding:7rpx;margin-bottom:8rpx}.tab{flex:1;padding:20rpx 0;text-align:center;border-radius:17rpx;color:#7B8496;font-size:28rpx}.tab--active{background:#fff;color:#35588F;font-weight:700;box-shadow:0 5rpx 16rpx rgba(53,88,143,.12)}
.form-panel{padding:28rpx 20rpx 22rpx}.card-title{display:block;font-size:32rpx;font-weight:700;color:#30394A;margin-bottom:8rpx}.card-desc{display:block;font-size:24rpx;color:#7B8496;margin-bottom:28rpx}.input{width:100%;height:92rpx;background:#F7F8FC;border:2rpx solid #E4EAF4;border-radius:20rpx;padding:0 24rpx;font-size:29rpx;box-sizing:border-box;margin-bottom:22rpx}.code-input{letter-spacing:5rpx}.btn-primary{width:100%!important;height:92rpx;line-height:92rpx}.fallback-actions{display:flex;justify-content:space-between;margin-top:24rpx}.switch-link{font-size:24rpx;color:#5579BC}.login-hint{text-align:center;color:#7B8496;padding:36rpx}.footer-note{display:block;text-align:center;color:#9AA6BA;font-size:22rpx;margin-top:28rpx}
