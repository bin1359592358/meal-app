.container{padding-bottom:190rpx}.section-title{font-size:27rpx;color:#667287;margin:28rpx 5rpx 14rpx;font-weight:650}.empty-state{min-height:65vh;display:flex;flex-direction:column;align-items:center;justify-content:center}.empty-icon{width:130rpx;height:130rpx;border-radius:50%;background:linear-gradient(145deg,#EAF1FF,#FFF4D8);color:#5579BC;font-size:46rpx;display:flex;align-items:center;justify-content:center;margin-bottom:25rpx}.empty-text{color:#7B8496;font-size:27rpx;line-height:1.65}.cart-item{padding:25rpx}.item-header,.item-footer{display:flex;align-items:center;justify-content:space-between}.item-info{display:flex;flex:1;flex-direction:column}.dish-name{font-size:30rpx;font-weight:700;color:#30394A}.seasoning-text{font-size:23rpx;color:#7B8496;margin-top:8rpx;line-height:1.45}.delete-btn{width:50rpx;height:50rpx;border-radius:50%;background:#FCEEEE;color:#D96868;display:flex;align-items:center;justify-content:center}.delete-icon{font-size:31rpx}.item-footer{margin-top:23rpx;padding-top:19rpx;border-top:1rpx solid #EDF1F6}.qty-control{display:flex;align-items:center}.qty-btn{width:52rpx;height:52rpx;border-radius:50%;background:#EEF2F8;color:#5579BC;display:flex;align-items:center;justify-content:center;font-size:30rpx}.qty-btn.plus{background:#5579BC;color:#fff}.qty-num{min-width:60rpx;text-align:center;font-weight:700;color:#30394A}.subtotal-price{font-size:31rpx;font-weight:750;color:#D96868}.people-card{display:flex;align-items:center;justify-content:center;gap:12rpx}.people-label{color:#7B8496}.note-input{width:100%;min-height:96rpx;color:#30394A;font-size:27rpx}.summary-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}.summary-label{color:#7B8496}.summary-value{color:#30394A;font-weight:600}.total-row{margin-bottom:0}.total-price{font-size:38rpx;color:#D96868;font-weight:800}.bottom-placeholder{height:110rpx}.bottom-bar{position:fixed;left:0;right:0;bottom:0;background:rgba(255,255,255,.97);padding:17rpx 24rpx calc(17rpx + env(safe-area-inset-bottom));box-shadow:0 -10rpx 30rpx rgba(53,88,143,.1);z-index:20}.submit-btn{width:100%!important;height:91rpx;line-height:91rpx;background:linear-gradient(135deg,#6388CB,#456BAE)!important;color:#fff!important;border-radius:24rpx!important;font-size:31rpx;font-weight:700;box-shadow:0 10rpx 22rpx rgba(53,88,143,.2)}.submit-btn::after{border:0}.submit-btn[disabled]{background:#C5CEDC!important;box-shadow:none}
