/* 购物车页面样式 */

/* ─── 分区标题 ─── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212121;
  margin: 32rpx 0 16rpx;
}

/* ─── 购物车菜品项 ─── */
.cart-item {
  position: relative;
}

.item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #212121;
}

.seasoning-text {
  font-size: 24rpx;
  color: #9E9E9E;
  margin-top: 6rpx;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
}

.delete-icon {
  font-size: 28rpx;
  color: #9E9E9E;
  line-height: 1;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ─── 数量控制 ─── */
.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 600;
}

.qty-btn.minus {
  background: #F5F5F5;
  color: #757575;
}

.qty-btn.plus {
  background: #FF6B35;
  color: #FFFFFF;
}

.qty-btn:active {
  opacity: 0.7;
}

.qty-num {
  min-width: 64rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
}

.subtotal-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #E53935;
}

/* ─── 用餐人数 ─── */
.people-card {
  display: flex;
  align-items: center;
}

.people-label {
  font-size: 28rpx;
  color: #757575;
  margin-left: 16rpx;
}

/* ─── 备注 ─── */
.note-card {
  padding: 16rpx 24rpx;
}

.note-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #212121;
  line-height: 1.6;
}

/* ─── 汇总卡片 ─── */
.summary-card {
  margin-top: 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #757575;
}

.summary-value {
  font-size: 28rpx;
  color: #212121;
  font-weight: 500;
}

.total-row .summary-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #E53935;
}

/* ─── 底部下单栏 ─── */
.bottom-placeholder {
  height: 140rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
  text-align: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.85;
}

.btn-disabled {
  opacity: 0.5;
}
