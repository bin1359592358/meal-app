<view class="container">
  <!-- 空购物车 -->
  <view wx:if="{{items.length === 0}}" class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-text">去菜单页面添加菜品吧</text>
  </view>

  <!-- 购物车有内容 -->
  <block wx:else>
    <!-- 菜品列表 -->
    <view class="section-title">已选菜品</view>
    <view class="card cart-item" wx:for="{{items}}" wx:key="index">
      <view class="item-header">
        <view class="item-info">
          <text class="dish-name">{{item.dish.name}}</text>
          <text class="seasoning-text" wx:if="{{item.seasonings}}">{{item.seasoningText || ''}}</text>
        </view>
        <view class="delete-btn" bindtap="onDelete" data-key="{{item.key}}">
          <text class="delete-icon">×</text>
        </view>
      </view>
      <view class="item-footer">
        <view class="qty-control">
          <view class="qty-btn minus" bindtap="onDecrease" data-key="{{item.key}}">
            <text>-</text>
          </view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn plus" bindtap="onIncrease" data-key="{{item.key}}">
            <text>+</text>
          </view>
        </view>
        <text class="subtotal-price">¥{{item.dish.price * item.quantity}}</text>
      </view>
    </view>

    <!-- 用餐人数 -->
    <view class="section-title">用餐人数</view>
    <view class="card people-card">
      <view class="qty-control">
        <view class="qty-btn minus" bindtap="onPeopleDecrease">
          <text>-</text>
        </view>
        <text class="qty-num">{{peopleCount}}</text>
        <view class="qty-btn plus" bindtap="onPeopleIncrease">
          <text>+</text>
        </view>
      </view>
      <text class="people-label">人</text>
    </view>

    <!-- 备注 -->
    <view class="section-title">备注</view>
    <view class="card note-card">
      <textarea
        class="note-input"
        placeholder="备注，如少放辣..."
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="200"
        auto-height
      />
    </view>

    <!-- 汇总卡片 -->
    <view class="card summary-card">
      <view class="summary-row">
        <text class="summary-label">菜品数量</text>
        <text class="summary-value">{{dishCount}} 道</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">用餐人数</text>
        <text class="summary-value">{{peopleCount}} 人</text>
      </view>
      <view class="divider"></view>
      <view class="summary-row total-row">
        <text class="summary-label">合计</text>
        <text class="summary-value total-price">¥{{totalPrice}}</text>
      </view>
    </view>

    <!-- 底部占位，防止按钮遮挡 -->
    <view class="bottom-placeholder"></view>
  </block>
</view>

<!-- 底部下单按钮 -->
<view wx:if="{{items.length > 0}}" class="bottom-bar">
  <button
    class="submit-btn {{submitting ? 'btn-disabled' : ''}}"
    bindtap="onSubmitOrder"
    disabled="{{submitting}}"
  >
    {{submitting ? '提交中...' : '确认下单'}}
  </button>
</view>
