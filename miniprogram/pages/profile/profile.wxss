/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ── Loading ── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #EEEEEE;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #9E9E9E;
  font-size: 28rpx;
  margin-top: 24rpx;
}

/* ── Card ── */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ── User Card ── */
.user-card {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #EEEEEE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 56rpx;
}

.avatar-icon-sm {
  font-size: 36rpx;
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #212121;
}

.edit-btn {
  font-size: 28rpx;
  margin-left: 16rpx;
}

.role-badge {
  display: inline-block;
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.role-chef {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

.role-guest {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.role-badge-sm {
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 12rpx;
}

/* ── Room Card ── */
.section-label {
  display: block;
  font-size: 26rpx;
  color: #9E9E9E;
  margin-bottom: 20rpx;
}

.room-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 20rpx;
}

.invite-code-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.invite-label {
  font-size: 26rpx;
  color: #757575;
  margin-right: 16rpx;
}

.invite-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
  letter-spacing: 4rpx;
  margin-right: 20rpx;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.copy-btn:active {
  opacity: 0.7;
}

.share-btn {
  width: 100% !important;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF6B35 !important;
  color: #FFFFFF !important;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx !important;
  border: none !important;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  opacity: 0.85;
}

/* ── Members ── */
.member-list {
  margin-top: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EEEEEE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  color: #212121;
  font-weight: 500;
}

.remove-btn {
  padding: 8rpx 24rpx;
  background: rgba(229, 57, 53, 0.1);
  color: #E53935;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.remove-btn:active {
  opacity: 0.7;
}

/* ── Menu Entry ── */
.menu-entry {
  padding: 36rpx 32rpx;
}

.menu-entry:active {
  background: #FAFAFA;
}

.menu-entry-left {
  display: flex;
  align-items: center;
}

.menu-entry-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.menu-entry-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #212121;
}

.arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ── Logout ── */
.logout-section {
  margin-top: 60rpx;
  padding-bottom: 80rpx;
}

.logout-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: #FFFFFF !important;
  color: #E53935 !important;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx !important;
  border: none !important;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  opacity: 0.85;
}

/* ── Leave Room Button ── */
.leave-btn {
  text-align: center;
  margin-top: 20rpx;
  padding: 16rpx 0;
  color: #E53935;
  font-size: 26rpx;
  font-weight: 500;
}

.leave-btn:active {
  opacity: 0.7;
}

/* ── Room List (RoomSwitch) ── */
.room-list {
  margin-top: 8rpx;
}

.room-list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.room-list-item:last-child {
  border-bottom: none;
}

.room-list-item--active {
  background: rgba(255, 107, 53, 0.04);
  border-radius: 12rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.room-list-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.room-list-name {
  font-size: 30rpx;
  color: #212121;
  font-weight: 500;
}

.room-list-role {
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 12rpx;
}

.room-list-code {
  font-size: 24rpx;
  color: #9E9E9E;
  letter-spacing: 2rpx;
}

.room-list-arrow {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 600;
  margin-left: 16rpx;
}

