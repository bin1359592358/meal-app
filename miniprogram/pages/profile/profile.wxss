.page{min-height:100vh;background:#FFFDF8}.profile-hero{background:linear-gradient(140deg,#EAF1FF,#F8FBFF 68%,#FFF2D2);padding:45rpx 32rpx 72rpx;display:flex;align-items:center}.profile-avatar{width:142rpx;height:142rpx;border-radius:50%;border:7rpx solid #fff;box-shadow:0 12rpx 30rpx rgba(53,88,143,.17);margin-right:24rpx}.user-info{flex:1;display:flex;flex-direction:column}.nickname-row{display:flex;align-items:center}.nickname{font-size:38rpx;font-weight:800;color:#30394A}.edit-btn{font-size:21rpx;color:#5579BC;background:#fff;padding:7rpx 15rpx;border-radius:99rpx;margin-left:15rpx}.profile-welcome{font-size:23rpx;color:#748096;margin:8rpx 0 12rpx}.role-badge,.role-badge-sm,.room-list-role{align-self:flex-start;padding:4rpx 14rpx;border-radius:99rpx;font-size:20rpx;font-weight:650}.role-chef{background:#FFF0C9;color:#986718}.role-guest{background:#EAF1FF;color:#5579BC}.profile-body{padding:0 24rpx calc(42rpx + env(safe-area-inset-bottom));margin-top:-35rpx;position:relative}.section-head{display:flex;justify-content:space-between;align-items:center}.section-label{display:block;font-size:25rpx;color:#6D788B;font-weight:650;margin-bottom:18rpx}.room-status{font-size:20rpx;color:#4F9B78;background:#E8F5EF;padding:5rpx 13rpx;border-radius:99rpx}.room-name{font-size:36rpx;font-weight:800;color:#30394A;margin-bottom:23rpx}.invite-code-row{display:flex;justify-content:space-between;align-items:center;background:#F4F7FC;border-radius:20rpx;padding:18rpx 20rpx}.invite-label{display:block;font-size:20rpx;color:#8A95A7}.invite-code{display:block;font-size:30rpx;color:#35588F;font-weight:750;letter-spacing:5rpx;margin-top:4rpx}.copy-btn{color:#5579BC;font-size:24rpx;font-weight:650;padding:12rpx 21rpx;background:#EAF1FF;border-radius:99rpx}.share-btn{height:82rpx;line-height:82rpx;background:linear-gradient(135deg,#6388CB,#456BAE)!important;color:#fff!important;border-radius:21rpx!important;font-size:28rpx;font-weight:700;margin-top:20rpx}.share-btn::after{border:0}.leave-btn{text-align:center;color:#A87676;font-size:23rpx;padding:19rpx 0 2rpx}.workbench{margin-bottom:20rpx}.workbench-title{margin:4rpx 5rpx 15rpx}.workbench-grid{display:flex;gap:17rpx}.workbench-item{flex:1;background:linear-gradient(145deg,#5579BC,#42669F);border-radius:27rpx;padding:23rpx;display:flex;flex-direction:column;box-shadow:0 10rpx 24rpx rgba(53,88,143,.16)}.workbench-item:nth-child(2){background:linear-gradient(145deg,#5F6F91,#465572)}.workbench-index{font-size:18rpx;color:#FFDFA0;letter-spacing:2rpx}.workbench-name{font-size:28rpx;color:#fff;font-weight:750;margin:18rpx 0 5rpx}.workbench-desc{font-size:20rpx;color:rgba(255,255,255,.72)}.room-list-item,.member-item{display:flex;align-items:center;padding:20rpx 0;border-bottom:1rpx solid #E9EEF5}.room-list-item:last-child,.member-item:last-child{border:0}.room-list-item--active{background:#F3F7FD;border-radius:17rpx;padding-left:15rpx;padding-right:15rpx}.room-list-info,.member-info{flex:1;display:flex;align-items:center}.room-list-name,.member-name{font-size:27rpx;color:#30394A;font-weight:600}.room-list-role,.role-badge-sm{margin-left:12rpx}.room-list-code{font-size:22rpx;color:#8C97A9;letter-spacing:2rpx}.room-list-arrow{color:#5579BC;margin-left:14rpx}.member-avatar{width:58rpx;height:58rpx;border-radius:50%;background:#EAF1FF;color:#5579BC;display:flex;align-items:center;justify-content:center;font-weight:700;margin-right:16rpx}.remove-btn{font-size:22rpx;color:#D96868;padding:9rpx 14rpx;background:#FCEEEE;border-radius:99rpx}.logout-btn{margin-top:26rpx;width:100%!important;background:#fff!important;color:#7B8496!important;border:1rpx solid #E1E7F0!important;border-radius:22rpx!important;font-size:27rpx}.logout-btn::after{border:0}
