<view class="page">
  <view class="loading-wrap" wx:if="{{loading}}"><view class="loading-spinner"></view><text class="loading-text">正在准备个人中心...</text></view>
  <block wx:else>
    <view class="profile-hero">
      <image class="profile-avatar" src="/images/brand/avatar.jpg" mode="aspectFill" />
      <view class="user-info"><view class="nickname-row"><text class="nickname">{{userInfo.nickname || '未设置昵称'}}</text><text class="edit-btn" bindtap="onEditNickname">编辑</text></view><text class="profile-welcome">欢迎回来，今天也要好好吃饭</text><view class="role-badge {{isChef ? 'role-chef' : 'role-guest'}}">{{isChef ? '主厨' : '食客'}}</view></view>
    </view>
    <view class="profile-body">
      <view class="card room-card" wx:if="{{activeRoom}}"><view class="section-head"><text class="section-label">当前餐桌</text><text class="room-status">用餐中</text></view><text class="room-name">{{roomDetail.name || activeRoom.name || ''}}</text><view class="invite-code-row"><view><text class="invite-label">邀请码</text><text class="invite-code">{{roomDetail.code || activeRoom.code || ''}}</text></view><view class="copy-btn" bindtap="onCopyInviteCode">复制</view></view><button class="share-btn" open-type="share">邀请好友加入</button><view class="leave-btn" wx:if="{{!isChef}}" bindtap="onLeaveRoom">退出餐桌</view><view class="leave-btn" wx:if="{{isChef}}" bindtap="onCloseRoom">关闭餐桌</view></view>
      <view class="card" wx:if="{{rooms.length > 1}}"><text class="section-label">我的餐桌 · {{rooms.length}}</text><view class="room-list"><view class="room-list-item {{activeRoom && item.id === activeRoom.id ? 'room-list-item--active' : ''}}" wx:for="{{rooms}}" wx:key="id" bindtap="onSwitchRoom" data-id="{{item.id}}"><view class="room-list-info"><text class="room-list-name">{{item.name}}</text><view class="room-list-role {{item.chef_id === userInfo.id ? 'role-chef' : 'role-guest'}}">{{item.chef_id === userInfo.id ? '主厨' : '食客'}}</view></view><text class="room-list-code">{{item.code}}</text><text class="room-list-arrow" wx:if="{{activeRoom && item.id === activeRoom.id}}">✓</text></view></view></view>
      <view class="workbench" wx:if="{{isChef}}"><text class="section-label workbench-title">主厨工作台</text><view class="workbench-grid"><view class="workbench-item" bindtap="onGoAdmin"><text class="workbench-index">01</text><text class="workbench-name">菜单管理</text><text class="workbench-desc">分类、菜品与口味</text></view><view class="workbench-item" bindtap="onGoOverview"><text class="workbench-index">02</text><text class="workbench-name">订单总览</text><text class="workbench-desc">出餐与营业数据</text></view></view></view>
      <view class="card" wx:if="{{members.length > 0}}"><text class="section-label">餐桌成员 · {{members.length}}</text><view class="member-list"><view class="member-item" wx:for="{{members}}" wx:key="id"><view class="member-avatar">友</view><view class="member-info"><text class="member-name">{{item.nickname}}</text><view class="role-badge-sm {{item.role === 'chef' ? 'role-chef' : 'role-guest'}}">{{item.role === 'chef' ? '主厨' : '食客'}}</view></view><view class="remove-btn" wx:if="{{isChef && item.role !== 'chef'}}" bindtap="onRemoveMember" data-member="{{item}}">移除</view></view></view></view>
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
  </block>
</view>
