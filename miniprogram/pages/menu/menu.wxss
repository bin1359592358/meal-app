.page-menu{display:flex;flex-direction:column;height:100vh;background:#FFFDF8}.menu-head{padding:22rpx 24rpx 16rpx;background:linear-gradient(145deg,#EAF1FF 0,#F8FBFF 70%,#FFF8E9 100%);border-radius:0 0 38rpx 38rpx;box-shadow:0 12rpx 34rpx rgba(53,88,143,.08);z-index:2}.brand-line{display:flex;align-items:center}.mini-avatar{width:86rpx;height:86rpx;border-radius:50%;border:5rpx solid #fff;box-shadow:0 6rpx 18rpx rgba(53,88,143,.17);margin-right:18rpx}.head-copy{display:flex;flex:1;flex-direction:column}.head-kicker{font-size:21rpx;letter-spacing:2rpx;color:#5579BC;font-weight:700}.room-name{font-size:33rpx;color:#30394A;font-weight:750;margin-top:4rpx}.head-action{padding:13rpx 24rpx;border-radius:99rpx;background:#fff;color:#5579BC;font-size:24rpx;border:1rpx solid #C9D6EC}
.search-row{display:flex;align-items:center;margin-top:20rpx}.search-input-wrap{height:74rpx;flex:1;display:flex;align-items:center;padding:0 22rpx;background:rgba(255,255,255,.9);border:1rpx solid #DCE5F3;border-radius:23rpx}.search-mark{font-size:36rpx;color:#5579BC;margin-right:12rpx}.search-input{flex:1;font-size:27rpx;color:#30394A}.search-placeholder{color:#A3ADBD}.search-clear{font-size:38rpx;color:#7B8496;padding:8rpx}
.recommend-card{margin-top:18rpx;min-height:118rpx;background:linear-gradient(120deg,#5579BC,#42669F);border-radius:25rpx;padding:20rpx 22rpx;display:flex;align-items:center;box-shadow:0 12rpx 24rpx rgba(53,88,143,.2);position:relative;overflow:hidden}.recommend-card:after{content:'';position:absolute;width:150rpx;height:150rpx;border-radius:50%;background:rgba(255,223,160,.2);right:-32rpx;top:-52rpx}.recommend-copy{display:flex;flex:1;flex-direction:column;position:relative;z-index:1}.recommend-kicker{font-size:17rpx;letter-spacing:2rpx;color:#FFDFA0}.recommend-title{font-size:29rpx;font-weight:700;color:#fff;margin:4rpx 0}.recommend-desc{font-size:21rpx;color:rgba(255,255,255,.75)}.recommend-button{position:relative;z-index:1;background:#FFDFA0;color:#35588F;border-radius:18rpx;padding:15rpx 20rpx;font-size:23rpx;font-weight:700}
.category-tabs{flex-shrink:0;width:100%;white-space:nowrap;padding:20rpx 0 10rpx}.category-track{display:inline-flex;padding:0 24rpx;gap:14rpx}.category-pill{display:flex;align-items:center;padding:14rpx 24rpx;border-radius:99rpx;background:#fff;border:1rpx solid #E4EAF4;color:#69758A;font-size:25rpx}.category-pill.active{background:#5579BC;border-color:#5579BC;color:#fff;box-shadow:0 7rpx 16rpx rgba(53,88,143,.18)}.cat-icon{margin-right:8rpx}.cat-name{font-weight:600}
.dish-list{flex:1;height:100%;padding:12rpx 24rpx 0;box-sizing:border-box}.list-heading{display:flex;align-items:baseline;justify-content:space-between;padding:8rpx 2rpx 18rpx}.list-title{font-size:31rpx;font-weight:750;color:#30394A}.list-count{font-size:22rpx;color:#8C97AA}.bottom-spacer{height:150rpx}
