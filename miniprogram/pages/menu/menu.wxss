/* pages/menu/menu.wxss */

.page-menu {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
}

/* ═══════════════════════════════════════
   搜索栏
   ═══════════════════════════════════════ */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  flex-shrink: 0;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
}

.search-placeholder {
  color: #BDBDBD;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.clear-icon {
  font-size: 24rpx;
  color: #999999;
}

/* 管理入口 */
.admin-icon {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}

.admin-emoji {
  font-size: 36rpx;
}

/* ═══════════════════════════════════════
   主体区域
   ═══════════════════════════════════════ */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ─── 左侧分类栏 ─── */
.category-sidebar {
  width: 200rpx;
  height: 100%;
  background: #FFFFFF;
  flex-shrink: 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  position: relative;
  transition: background 0.2s ease;
}

.category-item.active {
  background: #FFF3EE;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 48rpx;
  background: #FF6B35;
  border-radius: 0 3rpx 3rpx 0;
}

.cat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.cat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cat-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

.category-item.active .cat-name {
  color: #FF6B35;
  font-weight: 600;
}

.cat-count {
  font-size: 20rpx;
  color: #BDBDBD;
  margin-top: 4rpx;
}

.category-item.active .cat-count {
  color: #FF9E75;
}

/* ─── 右侧菜品列表 ─── */
.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx 20rpx 0;
}

/* 加载态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #BDBDBD;
}

/* 空态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #BDBDBD;
}

/* 搜索结果标题 */
.search-result-header {
  padding: 16rpx 8rpx;
}

.search-result-title {
  font-size: 24rpx;
  color: #9E9E9E;
}

/* 底部留白 */
.bottom-spacer {
  height: 140rpx;
}
