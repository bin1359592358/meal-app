<view class="page-menu">
  <view class="menu-head">
    <view class="brand-line">
      <image class="mini-avatar" src="/images/brand/avatar.jpg" mode="aspectFill" />
      <view class="head-copy">
        <text class="head-kicker">超大一碗饭</text>
        <text class="room-name">{{activeRoomName || '今天吃点什么？'}}</text>
      </view>
      <view class="head-action" wx:if="{{isChef}}" bind:tap="onAdminTap">管理</view>
    </view>
    <view class="search-row">
      <view class="search-input-wrap">
        <text class="search-mark">⌕</text>
        <input class="search-input" placeholder="搜索喜欢的菜" placeholder-class="search-placeholder" value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" />
        <view class="search-clear" wx:if="{{searchKeyword}}" bind:tap="onSearchClear">×</view>
      </view>
    </view>
    <view class="recommend-card" bind:tap="onRandomDish">
      <view class="recommend-copy">
        <text class="recommend-kicker">CHEF'S CHOICE</text>
        <text class="recommend-title">让厨娘替你选一道</text>
        <text class="recommend-desc">选择困难时，交给今天的灵感</text>
      </view>
      <view class="recommend-button">随机推荐</view>
    </view>
  </view>

  <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{!isSearchMode}}">
    <view class="category-track">
      <view wx:for="{{categories}}" wx:key="id" class="category-pill {{selectedCatIdx === index ? 'active' : ''}}" data-index="{{index}}" bind:tap="onCategoryTap">
        <text wx:if="{{item.icon}}" class="cat-icon">{{item.icon}}</text><text class="cat-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view class="dish-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="list-heading" wx:if="{{!isSearchMode && categories.length}}">
      <text class="list-title">{{categories[selectedCatIdx].name}}</text><text class="list-count">{{dishes.length}} 道可选</text>
    </view>
    <view class="loading-wrap" wx:if="{{loading}}"><view class="loading-spinner"></view><text class="loading-text">厨娘正在准备菜单...</text></view>
    <block wx:if="{{isSearchMode}}">
      <view class="list-heading" wx:if="{{searchResults.length}}"><text class="list-title">搜索结果</text><text class="list-count">找到 {{searchResults.length}} 道</text></view>
      <empty-state wx:if="{{searchResults.length === 0 && !loading}}" icon="⌕" text="没有找到相关菜品" />
      <dish-card wx:for="{{searchResults}}" wx:key="id" dish="{{item}}" quantity="{{qtyMap[item.id] || 0}}" bind:onAdd="onDishAdd" bind:onMinus="onDishMinus" bind:onTap="onDishTap" />
    </block>
    <block wx:else>
      <empty-state wx:if="{{dishes.length === 0 && !loading}}" icon="□" text="{{isChef ? '菜单还是空的，去添加第一道菜吧' : '主厨正在准备今日菜单'}}" buttonText="{{isChef ? '添加菜品' : ''}}" bind:onAction="onAdminTap" />
      <dish-card wx:for="{{dishes}}" wx:key="id" dish="{{item}}" quantity="{{qtyMap[item.id] || 0}}" bind:onAdd="onDishAdd" bind:onMinus="onDishMinus" bind:onTap="onDishTap" />
    </block>
    <view class="bottom-spacer"></view>
  </scroll-view>
  <cart-bar count="{{cartCount}}" total="{{cartTotal}}" bind:onCheckout="onCheckout" />
  <seasoning-panel dish="{{seasoningDish}}" visible="{{seasoningVisible}}" bind:onConfirm="onSeasoningConfirm" bind:onClose="onSeasoningClose" />
</view>
