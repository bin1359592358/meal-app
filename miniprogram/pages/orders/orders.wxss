.orders-page{min-height:100vh;background:#FFFDF8}.orders-head{padding:38rpx 30rpx 60rpx;background:linear-gradient(140deg,#EAF1FF,#F8FBFF 70%,#FFF3D8);display:flex;flex-direction:column}.orders-kicker{font-size:18rpx;letter-spacing:3rpx;color:#5579BC;font-weight:750}.orders-title{font-size:39rpx;font-weight:800;color:#30394A;margin:10rpx 0 8rpx}.orders-desc{font-size:24rpx;color:#748096}.orders-body{margin-top:-31rpx;position:relative}.overview-entry{display:flex;align-items:center;padding:24rpx;background:linear-gradient(120deg,#5579BC,#42669F);border:0}.overview-mark{width:64rpx;height:64rpx;border-radius:19rpx;background:#FFDFA0;color:#35588F;font-weight:800;display:flex;align-items:center;justify-content:center;margin-right:18rpx}.overview-left{flex:1;display:flex;flex-direction:column}.overview-title{font-size:28rpx;color:#fff;font-weight:700}.overview-desc{font-size:21rpx;color:rgba(255,255,255,.75);margin-top:5rpx}.overview-arrow{font-size:42rpx;color:#fff}.loading-more,.no-more{text-align:center;padding:30rpx;color:#8B96A8;font-size:23rpx}
