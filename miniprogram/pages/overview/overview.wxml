<!-- pages/overview/overview.wxml -->
<view class="page">

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>

    <!-- 统计卡片 -->
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-value">{{totalOrders}}</text>
        <text class="stat-label">进行中订单</text>
      </view>
      <view class="stat-card">
        <text class="stat-value stat-value--price">¥{{totalPrice}}</text>
        <text class="stat-label">进行中金额</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-card"><text class="stat-value">{{completedOrders}}</text><text class="stat-label">已完成订单</text></view>
      <view class="stat-card"><text class="stat-value stat-value--price">¥{{revenue}}</text><text class="stat-label">营业收入</text></view>
    </view>

    <!-- 排序切换 -->
    <view class="sort-bar">
      <text class="sort-title">已完成菜品销量</text>
      <view class="sort-toggle" bindtap="onToggleSort">
        <text>按{{sortBy === 'quantity' ? '数量' : '名称'}}</text>
        <text class="sort-icon">⇅</text>
      </view>
    </view>

    <!-- 菜品聚合列表 -->
    <view wx:if="{{salesSummary.length === 0}}" class="empty-section">
      <empty-state icon="📊" text="暂无订单数据" />
    </view>

    <view wx:else class="summary-list">
      <view class="summary-item" wx:for="{{salesSummary}}" wx:key="dish_id">
        <view class="summary-info">
          <text class="summary-name">{{item.dish_name}}</text>
          <view class="summary-meta">
            <text class="meta-item">共 {{item.total_quantity}} 份</text>
            <text class="meta-divider">|</text>
            <text class="meta-item">{{item.order_count}} 单</text>
          </view>
        </view>
        <view class="summary-bar">
          <view
            class="summary-bar-fill"
            style="width: {{completedOrders > 0 ? (item.order_count / completedOrders * 100) : 0}}%"
          ></view>
        </view>
      </view>
    </view>

  </block>
</view>
