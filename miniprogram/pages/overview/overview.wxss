/* pages/overview/overview.wxss */

.page {
  min-height: 100vh;
  background: #F7F8FC;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 80rpx;
}

/* ── Loading ── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E4EAF4;
  border-top-color: #5579BC;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #7B8496;
  font-size: 28rpx;
  margin-top: 24rpx;
}

/* ── Stats Row ── */
.stats-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-value {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #5579BC;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.stat-value--price {
  color: #D96868;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #7B8496;
}

/* ── Sort Bar ── */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.sort-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #30394A;
}

.sort-toggle {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(85, 121, 188, 0.1);
  border-radius: 8rpx;
  color: #5579BC;
  font-size: 24rpx;
  font-weight: 500;
}

.sort-toggle:active {
  opacity: 0.7;
}

.sort-icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* ── Empty Section ── */
.empty-section {
  padding: 80rpx 0;
}

/* ── Summary List ── */
.summary-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.summary-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F7F8FC;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.summary-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #30394A;
}

.summary-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: #7B8496;
}

.meta-divider {
  font-size: 24rpx;
  color: #DDDDDD;
  margin: 0 12rpx;
}

.summary-bar {
  height: 8rpx;
  background: #F7F8FC;
  border-radius: 4rpx;
  overflow: hidden;
}

.summary-bar-fill {
  height: 100%;
  background: #5579BC;
  border-radius: 4rpx;
  transition: width 0.3s ease;
  min-width: 4rpx;
}
.stats-row{gap:18rpx}.stat-card{border:1rpx solid rgba(85,121,188,.11);border-radius:27rpx}.stat-card:first-child{background:linear-gradient(145deg,#fff,#F5F8FE)}.stat-value{color:#35588F}.summary-item{background:#fff;border-radius:23rpx;border:1rpx solid rgba(85,121,188,.1)}.summary-bar-fill{background:linear-gradient(90deg,#5579BC,#7897CF)!important}
