/* 订单详情页面样式 */

/* ─── 加载状态 ─── */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9E9E9E;
}

/* ─── 分区标题 ─── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #212121;
  margin: 32rpx 0 16rpx;
}

/* ─── 订单头部卡片 ─── */
.order-header-card {
  padding: 28rpx 24rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #212121;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #757575;
}

.nickname {
  color: #9E9E9E;
}

/* ─── 菜品列表 ─── */
.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #212121;
}

.dish-seasoning {
  font-size: 24rpx;
  color: #9E9E9E;
  margin-top: 4rpx;
}

.dish-item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-qty {
  font-size: 26rpx;
  color: #757575;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dish-subtotal {
  font-size: 28rpx;
  font-weight: 600;
  color: #E53935;
  min-width: 80rpx;
  text-align: right;
}

/* ─── 备注 ─── */
.note-card {
  background: #FFF8E1;
  border-left: 6rpx solid #FF9800;
}

.note-text {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.6;
}

/* ─── 费用汇总 ─── */
.summary-card {
  padding: 20rpx 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #757575;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #212121;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #E53935;
}

.per-person {
  font-size: 28rpx;
  color: #FF6B35;
}

/* ─── 厨师操作按钮 ─── */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 40rpx 0 20rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  text-align: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-primary {
  background: #FF6B35;
  color: #FFFFFF;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid;
}

.btn-danger-outline {
  color: #E53935;
  border-color: #E53935;
  background: transparent;
}

.btn-danger-outline:active {
  background: rgba(229, 57, 53, 0.05);
}

.action-btn[disabled] {
  opacity: 0.4;
}

/* ─── 底部占位 ─── */
.bottom-placeholder {
  height: 40rpx;
}
