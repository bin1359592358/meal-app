/* 订单详情页面样式 */

/* ─── 加载状态 ─── */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7B8496;
}

/* ─── 分区标题 ─── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #30394A;
  margin: 32rpx 0 16rpx;
}

/* ─── 订单头部卡片 ─── */
.order-header-card {
  padding: 28rpx 24rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #30394A;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #7B8496;
}

.nickname {
  color: #7B8496;
}

/* ─── 菜品列表 ─── */
.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E4EAF4;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #30394A;
}

.dish-seasoning {
  font-size: 24rpx;
  color: #7B8496;
  margin-top: 4rpx;
}

.dish-item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-qty {
  font-size: 26rpx;
  color: #7B8496;
  background: #F7F8FC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dish-subtotal {
  font-size: 28rpx;
  font-weight: 600;
  color: #D96868;
  min-width: 80rpx;
  text-align: right;
}

/* ─── 备注 ─── */
.note-card {
  background: #FFF8E1;
  border-left: 6rpx solid #D69B3E;
}

.note-text {
  font-size: 26rpx;
  color: #7B8496;
  line-height: 1.6;
}

/* ─── 费用汇总 ─── */
.summary-card {
  padding: 20rpx 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #7B8496;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #30394A;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #D96868;
}

.per-person {
  font-size: 28rpx;
  color: #5579BC;
}

/* ─── 厨师操作按钮 ─── */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 40rpx 0 20rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  text-align: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-primary {
  background: #5579BC;
  color: #FFFFFF;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid;
}

.btn-danger-outline {
  color: #D96868;
  border-color: #D96868;
  background: transparent;
}

.btn-danger-outline:active {
  background: rgba(229, 57, 53, 0.05);
}

.action-btn[disabled] {
  opacity: 0.4;
}

/* ─── 底部占位 ─── */
.bottom-placeholder {
  height: 40rpx;
}
.order-header-card{background:linear-gradient(145deg,#fff,#F5F8FE)}.order-number{color:#35588F}.dish-item{border-bottom-color:#E8EDF5}.action-bar{background:rgba(255,255,255,.96);box-shadow:0 -8rpx 26rpx rgba(53,88,143,.09)}

.notify-card{margin-top:28rpx;background:linear-gradient(145deg,#F4F8FF,#FFF8E8);border-radius:27rpx;overflow:hidden;box-shadow:0 10rpx 28rpx rgba(53,88,143,.11)}.notify-art{display:block;width:100%;height:250rpx}.notify-copy{padding:22rpx 24rpx 8rpx;display:flex;flex-direction:column}.notify-title{font-size:30rpx;font-weight:750;color:#30394A}.notify-desc{font-size:23rpx;line-height:1.55;color:#7B8496;margin-top:7rpx}.notify-share-btn{margin:18rpx 24rpx 24rpx!important;height:80rpx;line-height:80rpx;background:linear-gradient(135deg,#6388CB,#456BAE)!important;color:#fff!important;border-radius:20rpx!important;font-size:27rpx;font-weight:700}.notify-share-btn::after{border:0}