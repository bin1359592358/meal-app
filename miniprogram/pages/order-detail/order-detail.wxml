<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 订单内容 -->
  <block wx:elif="{{order}}">
    <!-- 订单头部 -->
    <view class="card order-header-card">
      <view class="header-top">
        <text class="order-number">#{{order.id}}</text>
        <text class="status-badge" style="color: {{statusColor}}; background: {{statusColor}}15;">{{statusText}}</text>
      </view>
      <view class="header-info">
        <text class="info-text">{{formattedTime}}</text>
        <text wx:if="{{order.user_nickname}}" class="info-text nickname">下单人: {{order.user_nickname}}</text>
      </view>
    </view>

    <!-- 菜品列表 -->
    <view class="section-title">菜品明细</view>
    <view class="card">
      <view
        class="dish-item"
        wx:for="{{order.items}}"
        wx:key="index"
      >
        <view class="dish-item-left">
          <text class="dish-name">{{item.dish_name || item.dish.name}}</text>
          <text class="dish-seasoning" wx:if="{{item.seasoningText}}">{{item.seasoningText}}</text>
        </view>
        <view class="dish-item-right">
          <text class="dish-qty">×{{item.quantity}}</text>
          <text class="dish-subtotal">¥{{item.subtotal || item.dish.price * item.quantity}}</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view wx:if="{{order.note}}" class="section-title">备注</view>
    <view wx:if="{{order.note}}" class="card note-card">
      <text class="note-text">{{order.note}}</text>
    </view>

    <!-- 费用汇总 -->
    <view class="section-title">费用汇总</view>
    <view class="card summary-card">
      <view class="summary-row">
        <text class="summary-label">总价</text>
        <text class="summary-value total-price">{{totalPrice}}</text>
      </view>
      <view wx:if="{{hasPerPerson}}" class="summary-row">
        <text class="summary-label">人均 ({{order.people_count}}人)</text>
        <text class="summary-value per-person">{{perPersonPrice}}</text>
      </view>
    </view>

    <!-- 厨师操作按钮 -->
    <block wx:if="{{isChef}}">
      <!-- pending: 开始制作 / 取消 -->
      <view wx:if="{{order.status === 'pending'}}" class="action-bar">
        <button class="action-btn btn-primary" bindtap="onStartPrepare" disabled="{{actionInProgress}}">
          开始制作
        </button>
        <button class="action-btn btn-outline btn-danger-outline" bindtap="onCancel" disabled="{{actionInProgress}}">
          取消订单
        </button>
      </view>

      <!-- preparing: 标记出餐 / 取消 -->
      <view wx:elif="{{order.status === 'preparing'}}" class="action-bar">
        <button class="action-btn btn-primary" bindtap="onMarkServed" disabled="{{actionInProgress}}">
          标记出餐
        </button>
        <button class="action-btn btn-outline btn-danger-outline" bindtap="onCancel" disabled="{{actionInProgress}}">
          取消订单
        </button>
      </view>

      <!-- served: 完成 -->
      <view wx:elif="{{order.status === 'served'}}" class="action-bar">
        <button class="action-btn btn-primary" bindtap="onComplete" disabled="{{actionInProgress}}">
          完成
        </button>
      </view>
    </block>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </block>
</view>
