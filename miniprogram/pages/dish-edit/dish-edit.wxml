<!-- pages/dish-edit/dish-edit.wxml -->
<view class="page">

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <view class="form">

      <!-- 菜品名称 -->
      <view class="form-group">
        <text class="form-label">菜品名称</text>
        <input
          class="form-input"
          placeholder="菜品名称 *"
          value="{{name}}"
          bindinput="onNameInput"
          maxlength="30"
        />
      </view>

      <!-- 描述 -->
      <view class="form-group">
        <text class="form-label">描述</text>
        <textarea
          class="form-textarea"
          placeholder="描述"
          value="{{description}}"
          bindinput="onDescInput"
          maxlength="200"
          auto-height
        />
      </view>

      <!-- 价格 -->
      <view class="form-group">
        <text class="form-label">价格</text>
        <input
          class="form-input"
          type="digit"
          placeholder="价格 *"
          value="{{price}}"
          bindinput="onPriceInput"
        />
      </view>

      <!-- 分类 -->
      <view class="form-group">
        <text class="form-label">分类</text>
        <picker
          mode="selector"
          range="{{categories}}"
          range-key="name"
          value="{{categoryIndex}}"
          bindchange="onCategoryChange"
        >
          <view class="form-picker">
            <text>{{categories.length > 0 ? categories[categoryIndex].name : '请选择分类'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 标签 -->
      <view class="form-group">
        <text class="form-label">标签</text>
        <view class="tags-wrap">
          <view class="tag-chip" wx:for="{{tags}}" wx:key="*this">
            <text class="tag-text">{{item}}</text>
            <text
              class="tag-remove"
              bindtap="onRemoveTag"
              data-index="{{index}}"
            >✕</text>
          </view>
        </view>
        <view class="tag-add-row">
          <input
            class="form-input tag-input"
            placeholder="输入标签"
            value="{{tagInput}}"
            bindinput="onTagInput"
            maxlength="10"
          />
          <view class="tag-add-btn" bindtap="onAddTag">添加</view>
        </view>
      </view>

      <!-- 图片上传 -->
      <view class="form-group">
        <text class="form-label">图片</text>
        <view class="image-upload" bindtap="onChooseImage">
          <image
            wx:if="{{localImagePath || imageUrl}}"
            class="preview-image"
            src="{{localImagePath || imageUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">📷</text>
            <text class="upload-text">点击上传图片</text>
          </view>
        </view>
      </view>

      <!-- 是否可点 -->
      <view class="form-group form-group--row">
        <text class="form-label">可点单</text>
        <switch checked="{{isAvailable}}" bindchange="onAvailableChange" color="#5579BC" />
      </view>

      <view class="form-group">
        <view class="seasoning-title-row">
          <text class="form-label">调味配置</text>
          <view class="tag-add-btn" bindtap="onAddSeasoning">新增</view>
        </view>
        <view class="seasoning-editor" wx:for="{{seasonings}}" wx:key="index">
          <view class="seasoning-title-row">
            <input class="form-input seasoning-name" placeholder="调味名称，如辣度" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="onSeasoningInput" />
            <text class="tag-remove" data-index="{{index}}" bindtap="onRemoveSeasoning">删除</text>
          </view>
          <picker mode="selector" range="{{seasoningTypeNames}}" value="{{item.typeIndex}}" data-index="{{index}}" bindchange="onSeasoningTypeChange">
            <view class="form-picker">类型：{{seasoningTypeNames[item.typeIndex]}} <text>›</text></view>
          </picker>
          <input wx:if="{{item.type === 'single' || item.type === 'multi'}}" class="form-input" placeholder="选项用逗号或顿号分隔" value="{{item.optionsText}}" data-index="{{index}}" data-field="optionsText" bindinput="onSeasoningInput" />
          <view wx:if="{{item.type === 'scale'}}" class="seasoning-range">
            <input class="form-input" type="digit" placeholder="最小" value="{{item.min}}" data-index="{{index}}" data-field="min" bindinput="onSeasoningInput" />
            <input class="form-input" type="digit" placeholder="最大" value="{{item.max}}" data-index="{{index}}" data-field="max" bindinput="onSeasoningInput" />
            <input class="form-input" type="digit" placeholder="步长" value="{{item.step}}" data-index="{{index}}" data-field="step" bindinput="onSeasoningInput" />
          </view>
          <input wx:if="{{item.type === 'text'}}" class="form-input" type="number" placeholder="最多输入字数（默认 100）" value="{{item.max_length}}" data-index="{{index}}" data-field="max_length" bindinput="onSeasoningInput" />
        </view>
      </view>

      <!-- 保存按钮 -->
      <button class="save-btn" bindtap="onSave">保存</button>

      <!-- 删除按钮（仅编辑模式） -->
      <button
        class="delete-btn"
        wx:if="{{!isCreate}}"
        bindtap="onDelete"
      >删除菜品</button>

    </view>
  </block>
</view>
