/** 超大一碗饭：轻二次元厨娘主题设计系统 */
page {
  --color-primary: #5579BC;
  --color-primary-dark: #35588F;
  --color-primary-light: #EAF1FF;
  --color-accent: #FFDFA0;
  --color-blush: #F6B9B5;
  --color-bg: #FFFDF8;
  --color-card: #FFFFFF;
  --color-text: #30394A;
  --color-text-secondary: #7B8496;
  --color-desc: #7B8496;
  --color-border: #E4EAF4;
  --color-price: #D96868;
  --color-success: #4F9B78;
  --color-warning: #D69B3E;
  --color-danger: #D96868;
  background: #FFFDF8;
  color: #30394A;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}
.container { padding: 24rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); }
.flex-row { display:flex; align-items:center; }.flex-col{display:flex;flex-direction:column}.flex-1{flex:1}
.flex-center{display:flex;align-items:center;justify-content:center}.flex-between{display:flex;align-items:center;justify-content:space-between}
.card { background:#fff; border:1rpx solid rgba(85,121,188,.12); border-radius:28rpx; padding:28rpx; margin-bottom:20rpx; box-shadow:0 10rpx 30rpx rgba(53,88,143,.08); }
.text-primary{color:#5579BC}.text-price{color:#D96868;font-weight:700}.text-desc{color:#7B8496;font-size:24rpx}.text-bold{font-weight:600}.text-center{text-align:center}.text-ellipsis{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.btn-primary,.btn-outline,.btn-danger { border-radius:22rpx!important; font-size:30rpx; font-weight:600; text-align:center; }
.btn-primary{background:linear-gradient(135deg,#6388CB,#456BAE)!important;color:#fff!important;border:0;padding:20rpx 40rpx;box-shadow:0 10rpx 22rpx rgba(53,88,143,.22)}
.btn-primary::after,.btn-outline::after,.btn-danger::after{border:0}.btn-primary:active{opacity:.88}.btn-primary[disabled]{background:#C7D0DF!important;box-shadow:none}
.btn-outline{background:#fff;color:#5579BC;border:2rpx solid #B9CAE8;padding:18rpx 38rpx}.btn-danger{background:#D96868;color:#fff;border:0;padding:20rpx 40rpx}.btn-disabled{opacity:.45;pointer-events:none}
.tag{display:inline-block;padding:5rpx 16rpx;border-radius:99rpx;font-size:22rpx;margin-right:12rpx}.tag-primary{background:#EAF1FF;color:#5579BC}.tag-success{background:#E8F5EF;color:#4F9B78}.tag-warning{background:#FFF4D8;color:#A66F14}.tag-danger{background:#FCE9E9;color:#D96868}
.mt-sm{margin-top:12rpx}.mt-md{margin-top:24rpx}.mt-lg{margin-top:40rpx}.mb-sm{margin-bottom:12rpx}.mb-md{margin-bottom:24rpx}.mb-lg{margin-bottom:40rpx}.ml-sm{margin-left:12rpx}.mr-sm{margin-right:12rpx}.p-sm{padding:12rpx}.p-md{padding:24rpx}
.divider{height:1rpx;background:#E4EAF4;margin:20rpx 0}.section-title{font-size:28rpx;font-weight:650;color:#30394A;margin:30rpx 4rpx 16rpx}
.loading-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:88rpx 0}.loading-text{color:#7B8496;font-size:26rpx}.loading-spinner{width:56rpx;height:56rpx;border:5rpx solid #EAF1FF;border-top-color:#5579BC;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}
input,textarea{caret-color:#5579BC}
