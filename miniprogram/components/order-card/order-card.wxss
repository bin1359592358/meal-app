.order-card{background:#fff;border-radius:27rpx;padding:27rpx 25rpx;margin-bottom:18rpx;border:1rpx solid rgba(85,121,188,.11);box-shadow:0 9rpx 25rpx rgba(53,88,143,.07);position:relative;overflow:hidden}.order-card:before{content:'';position:absolute;left:0;top:0;bottom:0;width:6rpx;background:#5579BC}.order-card:active{opacity:.87}.card-header,.card-footer{display:flex;align-items:center;justify-content:space-between}.card-header{margin-bottom:16rpx}.order-id{font-size:27rpx;font-weight:750;color:#30394A}.status-badge{padding:6rpx 16rpx;border-radius:99rpx;font-size:21rpx;font-weight:650}.card-body{margin-bottom:18rpx}.dish-summary{font-size:26rpx;color:#5F6A7F;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.order-time{font-size:22rpx;color:#97A1B2}.card-footer-right{display:flex;align-items:center;gap:13rpx}.orderer-name,.people-count{font-size:22rpx;color:#7B8496}.people-count{padding:3rpx 11rpx;background:#F4F7FC;border-radius:99rpx}.total-price{font-size:30rpx;font-weight:750;color:#D96868}
