/* order-card 组件样式 */

.order-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-card:active {
  opacity: 0.85;
}

/* 顶部行 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-id {
  font-size: 28rpx;
  font-weight: 600;
  color: #212121;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 中间菜品摘要 */
.card-body {
  margin-bottom: 16rpx;
}

.dish-summary {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 底部行 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-time {
  font-size: 24rpx;
  color: #9E9E9E;
}

.card-footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.orderer-name {
  font-size: 24rpx;
  color: #757575;
}

.people-count {
  font-size: 24rpx;
  color: #9E9E9E;
  padding: 2rpx 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.total-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #E53935;
}
