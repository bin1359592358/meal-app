/* 菜品详情与调味底部面板 */
.panel-mask{position:fixed;top:0;right:0;bottom:0;left:0;background:rgba(35,45,64,.48);z-index:200;opacity:0;visibility:hidden;transition:all .25s}.panel-mask.show{opacity:1;visibility:visible}.panel-container{position:fixed;left:0;right:0;bottom:0;max-height:86vh;background:#FFFDF8;border-radius:38rpx 38rpx 0 0;z-index:201;transform:translateY(100%);transition:transform .28s;display:flex;flex-direction:column;padding-bottom:env(safe-area-inset-bottom);box-shadow:0 -20rpx 50rpx rgba(35,45,64,.16)}.panel-container.show{transform:translateY(0)}.panel-header{display:flex;align-items:center;justify-content:space-between;padding:31rpx 32rpx 19rpx}.panel-title{font-size:32rpx;font-weight:750;color:#30394A}.panel-close{width:54rpx;height:54rpx;border-radius:50%;background:#EEF2F8;display:flex;align-items:center;justify-content:center}.close-icon{font-size:25rpx;color:#6E798C}.dish-detail{display:flex;gap:20rpx;margin:0 32rpx 12rpx;padding:17rpx;background:#fff;border-radius:22rpx;border:1rpx solid #E4EAF4}.detail-image{width:150rpx;height:116rpx;border-radius:17rpx;flex:none}.detail-copy{display:flex;flex-direction:column;gap:8rpx}.detail-price{color:#D96868;font-size:34rpx;font-weight:750}.detail-description{color:#7B8496;font-size:24rpx;line-height:1.45}.panel-body{flex:1;padding:18rpx 32rpx;max-height:55vh;box-sizing:border-box}.seasoning-group{margin-bottom:34rpx}.group-label{font-size:27rpx;font-weight:700;color:#30394A;margin-bottom:16rpx;display:block}.option-list{display:flex;flex-wrap:wrap;gap:13rpx}.option-chip{padding:12rpx 25rpx;border-radius:99rpx;background:#F3F6FA;border:2rpx solid transparent}.option-chip.active{background:#EAF1FF;border-color:#5579BC}.option-text{font-size:25rpx;color:#68758B}.option-chip.active .option-text{color:#35588F;font-weight:650}.scale-wrap{display:flex;align-items:center}.scale-slider{flex:1;margin-right:18rpx}.scale-value{font-size:31rpx;font-weight:700;color:#5579BC;min-width:46rpx;text-align:center}.text-input{background:#F3F6FA;border:2rpx solid #E4EAF4;border-radius:18rpx;padding:19rpx 22rpx;font-size:27rpx;color:#30394A}.panel-footer{padding:18rpx 32rpx 23rpx;border-top:1rpx solid #E4EAF4;background:#fff}.confirm-btn{height:88rpx;background:linear-gradient(135deg,#6388CB,#456BAE);border-radius:24rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 10rpx 22rpx rgba(53,88,143,.2)}.confirm-btn.disabled{background:#BFC8D7;box-shadow:none}.confirm-btn-text{font-size:30rpx;color:#fff;font-weight:700}
