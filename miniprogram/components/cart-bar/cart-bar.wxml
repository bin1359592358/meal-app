<view class="cart-bar" wx:if="{{count > 0}}">
  <view class="cart-icon-wrap"><view class="cart-icon">碗</view><view class="cart-badge">{{count > 99 ? '99+' : count}}</view></view>
  <view class="cart-info"><text class="cart-summary">已选 {{count}} 道菜</text><text class="cart-total">¥{{total}}</text></view>
  <view class="cart-btn" bind:tap="onCheckout">去结算</view>
</view>
