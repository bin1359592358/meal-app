/* components/cart-bar/cart-bar.wxss */

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #333333;
  display: flex;
  align-items: center;
  padding: 0 0 0 24rpx;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─── 购物车图标 ─── */
.cart-icon-wrap {
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.cart-icon {
  width: 80rpx;
  height: 80rpx;
  background: #444444;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-emoji {
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #FF6B35;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  line-height: 1;
}

/* ─── 中间信息 ─── */
.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-summary {
  font-size: 24rpx;
  color: #BBBBBB;
  line-height: 1.4;
}

.cart-total {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1.3;
}

/* ─── 结算按钮 ─── */
.cart-btn {
  flex-shrink: 0;
  height: 100%;
  width: 220rpx;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-btn-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}
