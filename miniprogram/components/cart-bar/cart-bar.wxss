.cart-bar{position:fixed;left:22rpx;right:22rpx;bottom:calc(18rpx + env(safe-area-inset-bottom));height:104rpx;background:rgba(48,57,74,.97);border-radius:28rpx;display:flex;align-items:center;padding:0 12rpx 0 20rpx;z-index:100;box-shadow:0 15rpx 38rpx rgba(48,57,74,.24)}.cart-icon-wrap{position:relative;margin-right:17rpx}.cart-icon{width:68rpx;height:68rpx;border-radius:21rpx;background:#EAF1FF;color:#35588F;display:flex;align-items:center;justify-content:center;font-size:25rpx;font-weight:800}.cart-badge{position:absolute;right:-10rpx;top:-10rpx;min-width:31rpx;height:31rpx;padding:0 5rpx;border-radius:18rpx;background:#F6B9B5;color:#733F43;font-size:18rpx;font-weight:700;display:flex;align-items:center;justify-content:center}.cart-info{flex:1;display:flex;flex-direction:column}.cart-summary{font-size:21rpx;color:#C8D0DE}.cart-total{font-size:34rpx;color:#fff;font-weight:750}.cart-btn{height:76rpx;min-width:178rpx;border-radius:22rpx;background:linear-gradient(135deg,#6388CB,#456BAE);color:#fff;font-size:29rpx;font-weight:700;display:flex;align-items:center;justify-content:center}
