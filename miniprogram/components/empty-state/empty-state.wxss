/* components/empty-state/empty-state.wxss */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  line-height: 1.2;
}

.empty-text {
  color: #9E9E9E;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.action-btn {
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.action-btn:active {
  opacity: 0.85;
}
