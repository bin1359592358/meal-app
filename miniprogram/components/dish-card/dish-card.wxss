.dish-card{display:flex;background:#fff;border:1rpx solid rgba(85,121,188,.1);border-radius:27rpx;padding:18rpx;margin-bottom:18rpx;box-shadow:0 9rpx 26rpx rgba(53,88,143,.075);overflow:hidden}.dish-card:active{transform:scale(.994)}.dish-card.unavailable{opacity:.58}.dish-image-wrap{width:174rpx;height:174rpx;flex:none;border-radius:21rpx;overflow:hidden;position:relative;margin-right:20rpx}.dish-image{width:100%;height:100%}.dish-image-placeholder{width:100%;height:100%;background:linear-gradient(145deg,#EAF1FF,#FFF4D8);display:flex;align-items:center;justify-content:center}.placeholder-emoji{font-size:48rpx}.sold-out-overlay{position:absolute;top:0;right:0;bottom:0;left:0;background:rgba(48,57,74,.56);display:flex;align-items:center;justify-content:center}.sold-out-text{color:#fff;font-size:23rpx;font-weight:700;padding:7rpx 15rpx;border:1rpx solid rgba(255,255,255,.65);border-radius:99rpx}.dish-info{flex:1;min-width:0;display:flex;flex-direction:column}.dish-name{font-size:30rpx;font-weight:700;color:#30394A;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.dish-desc{font-size:23rpx;color:#7B8496;line-height:1.5;margin-top:7rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.dish-tags{display:flex;flex-wrap:wrap;gap:7rpx;margin-top:9rpx}.dish-tag{font-size:19rpx;color:#5579BC;background:#EAF1FF;padding:3rpx 11rpx;border-radius:99rpx}.dish-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:auto}.dish-price{font-size:33rpx;font-weight:800;color:#D96868}.qty-control{display:flex;align-items:center}.qty-btn{width:49rpx;height:49rpx;border-radius:50%;display:flex;align-items:center;justify-content:center}.qty-minus{background:#F5F7FB;border:1rpx solid #DCE4F0}.qty-plus{background:linear-gradient(135deg,#6388CB,#456BAE);box-shadow:0 5rpx 12rpx rgba(53,88,143,.22)}.qty-btn-text{font-size:31rpx;line-height:1}.qty-minus .qty-btn-text{color:#68758B}.qty-plus .qty-btn-text{color:#fff}.qty-count{font-size:26rpx;color:#30394A;min-width:42rpx;text-align:center;font-weight:700}.hidden{visibility:hidden;width:0;min-width:0;overflow:hidden;margin:0;padding:0}
