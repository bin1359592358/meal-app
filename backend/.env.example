# 数据库：留空时使用本地 SQLite，也可以配置云端 Turso
DATABASE_URL=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Cloudinary：可选，用于上传图片
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 应用
ENVIRONMENT=development
# 仅本地演示时改为 true，生产环境必须保持 false
AUTO_SEED=false
SECRET_KEY=change-this-to-random-string
TOKEN_EXPIRE_DAYS=30

# 微信小程序
WX_APPID=
WX_SECRET=
